# Use NVIDIA_API_KEYS for key pool rotation. One key is also OK.
NVIDIA_API_KEYS=nvapi-key-1,nvapi-key-2
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Required for login, quota and admin panel on Vercel.
AUTH_SECRET=change-this-long-random-secret
ADMIN_EMAIL=root
ADMIN_PASSWORD=change-this-admin-password

# Vercel KV or Upstash Redis REST API.
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

ALLOW_PUBLIC_REGISTER=true
REQUIRE_INVITE_CODE=true
DEFAULT_DAILY_CREDITS=30
DEFAULT_TOTAL_CREDITS=1000
ADMIN_BYPASS_QUOTA=true
TURNSTILE_SECRET_KEY=

RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=12
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
LOGIN_RATE_LIMIT_MAX=8
REGISTER_RATE_LIMIT_WINDOW_SECONDS=3600
REGISTER_RATE_LIMIT_MAX=4
MAX_HISTORY_MESSAGES=18
MAX_OUTPUT_TOKENS=1800
